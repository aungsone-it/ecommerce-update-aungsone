# Copy to `.env` for local dev. Vite only exposes variables prefixed with `VITE_`.
# For production, set the same keys in your host’s dashboard (Vercel, Netlify, etc.).

# --- Supabase (required for API; many setups use `utils/supabase/info.tsx` instead) ---
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: grid/list product images use Storage image transformations (smaller downloads → less egress).
# Requires a Supabase plan that supports transformations. Try 400–600; unset = full-size URLs (default).
# VITE_SUPABASE_THUMB_MAX=480

# --- Vendor subdomains (optional) ---
# Apex domain only, no protocol: `example.com`
# Required for multi-part public suffixes (e.g. .co.uk) where auto-detection is wrong.
# VITE_VENDOR_SUBDOMAIN_BASE_DOMAIN=example.com

# JSON map: short DNS label → real store slug in /store/:slug
# Example: {"gogo":"go-go","myshop":"my-shop"}
# VITE_VENDOR_SUBDOMAIN_SLUG_MAP={}

# --- Payments (optional) ---
# VITE_STRIPE_PUBLISHABLE_KEY=

# Vercel Edge middleware (server env, not VITE_ — set in Vercel project settings):
# VENDOR_SUBDOMAIN_BASE_DOMAIN=example.com
# VENDOR_SUBDOMAIN_SLUG_MAP={"gogo":"go-go"}
